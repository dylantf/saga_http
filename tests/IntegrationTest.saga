module IntegrationTest

import Std.Actor (Process, Timer, beam_actor)
import Std.BitString
import Std.Test (Testing, Test, describe, test, assert_true)
import SagaHttp.Http
import SagaHttp.Http (Chunked)
import SagaHttp.Tcp

val test_port = 18765

fun handle : Http.Request -> Http.Response
handle req =
  if req.path
    == "/stream" then Http.stream 200 (Dict.from_list [("Content-Type", "text/plain")]) (fun () -> {
    write_chunk! (BitString.from_string "alpha")
    write_chunk! (BitString.from_string "beta")
  })
  else case req.body {
    Just body -> case BitString.to_string body {
      Ok s -> Http.text 200 $"echo: {s}"
      Err _ -> Http.text 500 "binary body"
    }
    Nothing -> Http.text 200 $"path: {req.path}"
  }

# Convert a received BitString to a String for assertion. Tests only use
# ASCII responses, so the conversion always succeeds.
fun resp_to_string : BitString -> String
resp_to_string bs = case BitString.to_string bs {
  Ok s -> s
  Err _ -> "<non-utf8 response>"
}

# Reads from the socket until the server closes the connection (or times out
# with no data). This matches what a real client does — necessary for
# streamed responses where the body arrives across multiple sends.
fun recv_all : Tcp.Socket -> BitString -> Result BitString String
recv_all sock acc = case Tcp.recv sock 0 5000 {
  Ok more -> recv_all sock (acc <> more)
  Err _ -> if BitString.size acc == 0 then Err "no data" else Ok acc
}

# Send raw bytes on a fresh connection, return the response as a String.
fun request : String -> Result String String
request raw = case Tcp.connect "127.0.0.1" test_port 5000 {
  Err e -> Err e
  Ok sock -> {
    let _ = Tcp.send sock (BitString.from_string raw)
    let r = recv_all sock <<>>
    let _ = Tcp.close sock
    case r {
      Ok bs -> Ok (resp_to_string bs)
      Err e -> Err e
    }
  }
}

# Send two requests on a single connection, returning each response separately.
fun two_requests : String -> String -> Result (String, Result String String) String
two_requests first second = case Tcp.connect "127.0.0.1" test_port 5000 {
  Err e -> Err e
  Ok sock -> {
    let _ = Tcp.send sock (BitString.from_string first)
    let r1 = Tcp.recv sock 0 5000
    case r1 {
      Err e -> {
        let _ = Tcp.close sock
        Err e
      }
      Ok resp1 -> {
        let _ = Tcp.send sock (BitString.from_string second)
        let r2 = Tcp.recv sock 0 5000
        let _ = Tcp.close sock
        let r2_str = case r2 {
          Ok bs -> Ok (resp_to_string bs)
          Err e -> Err e
        }
        Ok (resp_to_string resp1, r2_str)
      }
    }
  }
}

fun assert_contains : String -> String -> Unit needs {Test}
assert_contains needle haystack =
  if String.contains needle haystack then assert! True ""
  else assert! False $"expected to contain {needle}, got: {haystack}"

pub fun tests : Unit -> Unit needs {Testing}
tests () = {
  describe "integration" (fun () -> {
    let _ = {
      let _ = spawn! (fun () -> {
        let _ = Http.serve ({ Http.default_config | port: test_port }) handle
        ()
      })
      sleep! 200
    } with beam_actor

    test "GET returns 200 with body" (fun () -> {
      case request "GET /test HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n" {
        Ok r -> {
          assert_contains "HTTP/1.1 200 OK" r
          assert_contains "path: /test" r
        }
        Err _ -> assert_true False
      }
    })

    test "POST echoes body" (fun () -> {
      case request "POST /echo HTTP/1.1\r\nHost: localhost\r\nContent-Length: 5\r\nConnection: close\r\n\r\nhello" {
        Ok r -> {
          assert_contains "HTTP/1.1 200 OK" r
          assert_contains "echo: hello" r
        }
        Err _ -> assert_true False
      }
    })

    test "HEAD returns headers without body" (fun () -> {
      case request "HEAD /test HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n" {
        Ok r -> {
          assert_contains "HTTP/1.1 200 OK" r
          assert_contains "Content-Length: 11" r
          # body 'path: /test' is 11 bytes, but should not appear
          if String.contains "path: /test" r then assert_true False
          else assert_true True
        }
        Err _ -> assert_true False
      }
    })

    test "garbled request returns 400" (fun () -> {
      case request "NOT_HTTP\r\n\r\n" {
        Ok r -> assert_contains "HTTP/1.1 400 Bad Request" r
        Err _ -> assert_true False
      }
    })

    test "oversized Content-Length returns 413" (fun () -> {
      case request "POST /huge HTTP/1.1\r\nHost: localhost\r\nContent-Length: 999999999\r\n\r\n" {
        Ok r -> assert_contains "HTTP/1.1 413 Payload Too Large" r
        Err _ -> assert_true False
      }
    })

    test "HTTP/1.1 keep-alive: two requests on one connection" (fun () -> {
      let req1 = "GET /a HTTP/1.1\r\nHost: localhost\r\n\r\n"
      let req2 =
        "GET /b HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n"
      case two_requests req1 req2 {
        Ok (resp1, Ok resp2) -> {
          assert_contains "path: /a" resp1
          assert_contains "path: /b" resp2
        }
        _ -> assert_true False
      }
    })

    test "HTTP/1.0 default closes after one request" (fun () -> {
      let req1 = "GET /a HTTP/1.0\r\n\r\n"
      let req2 = "GET /b HTTP/1.0\r\n\r\n"
      case two_requests req1 req2 {
        # First response succeeds, second recv fails because server closed
        Ok (resp1, Err _) -> assert_contains "path: /a" resp1
        _ -> assert_true False
      }
    })

    test "chunked request body, single chunk" (fun () -> {
      let req = "POST /echo HTTP/1.1\r\nHost: localhost\r\nTransfer-Encoding: chunked\r\nConnection: close\r\n\r\n"
        <> "5\r\nhello\r\n0\r\n\r\n"
      case request req {
        Ok r -> {
          assert_contains "HTTP/1.1 200 OK" r
          assert_contains "echo: hello" r
        }
        Err _ -> assert_true False
      }
    })

    test "chunked request body, multiple chunks" (fun () -> {
      let req = "POST /echo HTTP/1.1\r\nHost: localhost\r\nTransfer-Encoding: chunked\r\nConnection: close\r\n\r\n"
        <> "5\r\nhello\r\n6\r\n world\r\n0\r\n\r\n"
      case request req {
        Ok r -> assert_contains "echo: hello world" r
        Err _ -> assert_true False
      }
    })

    test "chunked request honors chunk extensions" (fun () -> {
      let req = "POST /echo HTTP/1.1\r\nHost: localhost\r\nTransfer-Encoding: chunked\r\nConnection: close\r\n\r\n"
        <> "5;name=value\r\nhello\r\n0\r\n\r\n"
      case request req {
        Ok r -> assert_contains "echo: hello" r
        Err _ -> assert_true False
      }
    })

    test "chunked request with trailers (ignored)" (fun () -> {
      let req = "POST /echo HTTP/1.1\r\nHost: localhost\r\nTransfer-Encoding: chunked\r\nConnection: close\r\n\r\n"
        <> "5\r\nhello\r\n0\r\nX-Trailer: ok\r\n\r\n"
      case request req {
        Ok r -> assert_contains "echo: hello" r
        Err _ -> assert_true False
      }
    })

    test "Transfer-Encoding + Content-Length together returns 400" (fun () -> {
      let req = "POST /echo HTTP/1.1\r\nHost: localhost\r\nTransfer-Encoding: chunked\r\nContent-Length: 5\r\n\r\n"
        <> "5\r\nhello\r\n0\r\n\r\n"
      case request req {
        Ok r -> assert_contains "HTTP/1.1 400 Bad Request" r
        Err _ -> assert_true False
      }
    })

    test "unsupported Transfer-Encoding returns 400" (fun () -> {
      let req =
        "POST /echo HTTP/1.1\r\nHost: localhost\r\nTransfer-Encoding: gzip\r\n\r\nbody"
      case request req {
        Ok r -> assert_contains "HTTP/1.1 400 Bad Request" r
        Err _ -> assert_true False
      }
    })

    test "Expect: 100-continue gets interim 100 Continue then final 200" (fun () -> {
      let req =
        "POST /echo HTTP/1.1\r\nHost: localhost\r\nExpect: 100-continue\r\nContent-Length: 5\r\nConnection: close\r\n\r\n"
        <> "hello"
      case request req {
        Ok r -> {
          assert_contains "HTTP/1.1 100 Continue" r
          assert_contains "HTTP/1.1 200 OK" r
          assert_contains "echo: hello" r
        }
        Err _ -> assert_true False
      }
    })

    test "Expect: 100-continue is ignored for HTTP/1.0" (fun () -> {
      let req =
        "POST /echo HTTP/1.0\r\nHost: localhost\r\nExpect: 100-continue\r\nContent-Length: 5\r\n\r\n"
        <> "hello"
      case request req {
        Ok r -> {
          # No interim response — straight to 200
          assert_contains "HTTP/1.1 200 OK" r
          assert_contains "echo: hello" r
          if String.contains "100 Continue" r then assert_true False
          else assert_true True
        }
        Err _ -> assert_true False
      }
    })

    test "unsupported Expect value returns 417" (fun () -> {
      let req = "POST /echo HTTP/1.1\r\nHost: localhost\r\nExpect: weird\r\nContent-Length: 5\r\nConnection: close\r\n\r\nhello"
      case request req {
        Ok r -> assert_contains "HTTP/1.1 417 Expectation Failed" r
        Err _ -> assert_true False
      }
    })

    test "oversized request line returns 400" (fun () -> {
      # Path of 9000 bytes pushes the request line past the 8KB default.
      let big_path = String.repeat 9000 "a"
      let req = $"GET /{big_path} HTTP/1.1\r\nHost: localhost\r\n\r\n"
      case request req {
        Ok r -> assert_contains "HTTP/1.1 400 Bad Request" r
        Err _ -> assert_true False
      }
    })

    test "oversized header line returns 400" (fun () -> {
      let big = String.repeat 9000 "x"
      let req = $"GET / HTTP/1.1\r\nHost: localhost\r\nX-Big: {big}\r\n\r\n"
      case request req {
        Ok r -> assert_contains "HTTP/1.1 400 Bad Request" r
        Err _ -> assert_true False
      }
    })

    test "streamed response uses Transfer-Encoding: chunked" (fun () -> {
      case request "GET /stream HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n" {
        Ok r -> {
          assert_contains "HTTP/1.1 200 OK" r
          assert_contains "Transfer-Encoding: chunked" r
          # Each chunk: <hex-size>\r\n<data>\r\n; terminated by 0\r\n\r\n
          assert_contains "5\r\nalpha\r\n" r
          assert_contains "4\r\nbeta\r\n" r
          assert_contains "0\r\n\r\n" r
        }
        Err _ -> assert_true False
      }
    })
  })
}
